@InProceedings{Dhamotharan2025,
  author   = {Dhamotharan C and Suganthi B and Venkateswaran Vijayan and Devadharshini R and K. J. and D. E},
  title    = {Sensor based Energy Efficient Intelligent Parking System},
  year     = {2025},
  abstract = {This research study proposes an intelligent parking system to enhance urban parking efficiency by leveraging a sensor-based network for real-time occupancy monitoring. The proposed system aims to optimize parking space utilization by automating entry and exit processes, thereby reducing congestion and improving traffic flow within parking areas. A core component of Intelligent Parking System is its route guidance mechanism, which directs drivers to available parking spots through navigation updates. By integrating real-time data analytics and predictive modelling, the system ensures that users receive precise information about vacant spaces, minimizing delays and unnecessary vehicle movement. The system relays parking availability and navigation assistance via digital displays, mobile applications, and in-vehicle communication systems, streamlining the search process and improving overall efficiency. By reducing fuel consumption associated with prolonged parking searches and mitigating environmental impact, this system supports sustainable urban transportation. Through its automated infrastructure and intelligent navigation, the proposed system enhances the parking experience, fostering a more efficient and organized urban mobility framework.},
  cites    = {Dhamotharan2025},
  doi      = {10.1109/ICIMA64861.2025.11073870},
  url      = {https://www.semanticscholar.org/paper/0bea01c21802fa23456a44f3896cd65d04c31b54},
