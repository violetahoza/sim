@Article{Belcastro2025,
  author   = {Loris Belcastro and Fabrizio Marozzo and A. Orsino and Domenico Talia and Paolo Trunfio},
  title    = {Navigating the Edge-Cloud Continuum: A State-of-Practice Survey},
  year     = {2025},
  abstract = {The edge-cloud continuum has emerged as a transformative paradigm that meets the growing demand for low-latency, scalable, end-to-end service delivery by integrating decentralized edge resources with centralized cloud infrastructures. Driven by the exponential growth of IoT-generated data and the need for real-time responsiveness, this continuum features multi-layered architectures. However, its adoption is hindered by infrastructural challenges, fragmented standards, and limited guidance for developers and researchers. Existing surveys rarely tackle practical implementation or recent industrial advances. This survey closes those gaps from a developer-oriented perspective, introducing a conceptual framework for navigating the edge-cloud continuum. We systematically examine architectural models, performance metrics, and paradigms for computation, communication, and deployment, together with enabling technologies and widely used edge-to-cloud platforms. We also discuss real-world applications in smart cities, healthcare, and Industry 4.0, as well as tools for testing and experimentation. Drawing on academic research and practices of leading cloud providers, this survey serves as a practical guide for developers and a structured reference for researchers, while identifying open challenges and emerging trends that will shape the future of the continuum.},
  cites    = {Belcastro2025},
  doi      = {10.1109/ACCESS.2026.3673012},
  url      = {https://www.semanticscholar.org/paper/2cf25e416d033304d15167ef19e7a078de0dcc59},
}

@InProceedings{Bhowmik2026,
  author   = {Pritam Bhowmik and Rupa Mishra and Saranya S T and Pooja S},
  title    = {Optimized Smart Parking Management System for Urban Mobility},
  year     = {2026},
  abstract = {Due to the rise in the number of vehicles, managing traffic and efficiently allotting parking spaces has become a major challenge today. A considerable proportion of traffic congestion arises from drivers searching for parking spaces, leading to fuel and time wastage and increased driver frustration. This study proposes a Smart Parking Management System (SPMS) to manage transportation system more effectively and intelligently by integrating Artificial Intelligence and Machine Learning-enabled Optical Character Recognition-based license plate recognition, QR-code based access control, Internet of things sensors, and Arduino-based microcontrollers to achieve real-time parking slot detection, allocation and authorization. To calculate precise distances between vehicles and nearby objects, ultrasonic sensors are coupled with Arduino units. The processed sensor data assists drivers through visual and auditory alerts, thereby enhancing parking accuracy and reducing collision risk. Additionally, a dual-layer security framework using AES-256 encryption and Transport Layer Security protects sensitive vehicle and user data, and a decentralized microcontroller-based barricade control mechanism enables low-latency and scalable parking operations. Experimental validation demonstrates that the proposed SPMS achieves reliable and timely performance with high OCR accuracy at low image resolutions ($30-33 \text{DPI}$), reducing hardware cost while maintaining system reliability and highlighting its potential to streamline urban parking operations.},
  cites    = {Bhowmik2026},
  doi      = {10.1109/ODICON66687.2026.11470600},
  url      = {https://www.semanticscholar.org/paper/5f39e490c13b85a47861fe21028c610799fbbe91},
}

