@InProceedings{Abbas2025,
  author   = {Aalia Abbas and Fadia Ali Khan and Noshina Ishaque and Zeeshan Habib},
  title    = {A Survey on Efficient Data Management in IoT Systems to Overcome Complexity},
  year     = {2025},
  abstract = {Internet of Things (IoT) systems have been taken to a dynamic level through real-time monitoring, wireless integration and smart automation. Nevertheless, the important issues that one could not ignore are data generation in the various devices, transfer and management of the IT devices involved. The complexities may lead to exponential latency, reduction in the ratio of system reliability among other unavoidable performance problems. All these increase the complexity of design of IoT systems. This study explores recent trends, opportunities of current architectures and state-of-theart solutions of IoT data management in order to integrate data analytics, edge computing, cloud-based solutions. Recent developments can give an insight to minimize complex data management by exchanging adaptive and real-time filtering and bandwidth optimization mechanisms. Also, the problems regarding the data processing based on intelligent algorithms of predictive maintenance and anomaly detection in centralized networks have been discussed. Block-chain implementations and light weight encryption schemes solve the privacy issues in the eco system of IoT. Critical analysis has also been used to validate the deployment and performance measures of the various applications such as smart cities, industrial automation and intelligent healthcare system. The most noticeable issues of heterogenous environment are data redundancy, computational load and interoperability of devices and protocol. Through critical issues and possible possibilities of big and complex data, the research will be valuable in proposing the scaling of applications using the IoT, where the reliance of intelligent and secure technologies will enhance the strength of the IoT network to process various data.},
  cites    = {Abbas2025},
  doi      = {10.1109/ICECT66235.2025.11381668},
  url      = {https://www.semanticscholar.org/paper/7e70bff6c7afdcbd5f92bdae49a751e9df80ed8c},
}

