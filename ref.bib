@InProceedings{Chouragadey2025,
  author   = {Pratik Chouragadey and Lubhanshu Kawadkar and B. Rathore},
  title    = {Comparative Analysis of Communication Protocols: MQTT, HTTP, TCP, UDP, and Websocket},
  year     = {2025},
  abstract = {In this paper, experimental comparison of five IoT used Internet based protocols is drawn. Applications such as UDP, TCP, HTTP, Websocket and MQTT are all built on the same program and hardware platform, i.e. ESP32 micro-controller, MQ-135, DHT11 sensors, centralized Python server. In this study, one-way is being measured latency, application throughput, in bytes per second, the average packet size and the percentage of packet loss when in an indoor set-up with 1,000 consecutive sensor transmissions over a single protocol. The results have shown that apparent performance is equalized Connection-oriented data delivery is stable with connection-less UDP being the lowest median latency at the expense of measurable packet loss, as well as, with connection-less UDP being the highest median latency. WebSocket offers a trade-off, which offers two-way communication continuously. Per request HTTP is the most overhead consuming and latency variability is the highest. Evidence-based recommendations are provided on the choice of the protocol, limitations are addressed, including the use of one hardware testbed and fixed protocol parameters. The suggested work in the future is energy profiling, TLS overhead, device density scaling as well as testing in realistic urban wireless settings.},
  cites    = {Chouragadey2025},
  doi      = {10.1109/iCONECCT67014.2025.11469821},
  url      = {https://www.semanticscholar.org/paper/c31f9d81f6e23d2c6781b5e47d2c2139d4bfce46},
}

