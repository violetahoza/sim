@InProceedings{Montazeri2026,
  author   = {Dina Montazeri and Mohammed Al-Hubaishi},
  title    = {Performance Analysis and Machine Learning-based Classification of DDS vs MQTT IoT Communication Protocols},
  year     = {2026},
  abstract = {Selecting the right communication protocol is crucial for the performance and scalability of an IoT system. In this paper, we compare two popular publish-subscribe protocolsData Distribution Service (DDS) and Message Queuing Telemetry Transport (MQTT)-under identical settings, because we evaluate the protocols based on bandwidth usage, latency, reliability, and resource utilisation. Our experiments model realistic traffic rather than idealised ones, and we also create temporal and QoSinspired features to better characterise each protocol over time. We use multiple machine learning models, including ensembles, to show that protocol-specific traffic can be classified with extremely high accuracy, and bandwidth- and delivery-related features consistently have the largest impact on the predictions. Taken together, the results provide practical, data-driven guidelines for choosing and operating protocols in next-generation IoT deployments.},
  cites    = {Montazeri2026},
  doi      = {10.1109/IDCIoT67589.2026.11455884},
  url      = {https://www.semanticscholar.org/paper/d87a2f28a54cf6a8605fc2c0a5da2df3ec89fb8f},
}

@Misc{Naik2017,
  author   = {N. Naik},
  title    = {Choice of effective messaging protocols for IoT systems: MQTT, CoAP, AMQP and HTTP},
  year     = {2017},
  abstract = {The standard and real-time communication technology is an unalloyed inevitability for the development of Internet of Things (IoT) applications. However, the selection of a standard and effective messaging protocol is a challenging and daunting task for any organisation because it depends on the nature of the IoT system and its messaging requirements. Copious messaging protocols have been developed and employed by various organisations based on their requirements in the last two decades. Though, none of them is able to support all messaging requirements of all types of IoT systems. Messaging protocol is an ongoing dilemma for the IoT industry; consequently, it is important to understand the pros and cons of the widely accepted and emerging messaging protocols for IoT systems to determine their best-fit scenarios. Therefore, this paper presents an evaluation of the four established messaging protocols MQTT, CoAP, AMQP and HTTP for IoT systems. Firstly, it presents the broad comparison among these messaging protocols to introduce their characteristics comparatively. Afterwards, it performs a further in-depth and relative analysis based on some interrelated criteria to gain insight into their strengths and limitations. Thus, based on this detailed evaluation, the user can decide their appropriate usage in various IoT systems according to their requirements and suitability.},
  doi      = {10.1109/SYSENG.2017.8088251},
  url      = {https://www.semanticscholar.org/paper/353b9dca01110738b38ce7aa00fed57df969540d},
}

